{
  "name": "ironmen",
  "version": "1.0.0",
  "description": "IronMen Brotherhood — website and installable app",
  "private": true,
  "scripts": {
    "start": "python api/server.py",
    "icons": "python icons/generate_png.py",
    "cap:init": "npx cap init IronMen org.ironmen.brotherhood --web-dir .",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios"
  },
  "capabilities": {
    "webDir": "."
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}